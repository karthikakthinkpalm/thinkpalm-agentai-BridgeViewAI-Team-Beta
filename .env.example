# Required: Your Groq API key for LLaMA model orchestration
GROQ_API_KEY=your_groq_api_key_here

# Optional: Your Gemini API key if using gemini fallback/pipeline
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override the fallback chain of models
# GROQ_MODEL_FALLBACK_CHAIN=llama-3.1-8b-instant,gemma2-9b-it

# Optional: Disable specific LLM capabilities to force config-only paths
# DISABLE_LLM_TOOL_FALLBACK=true          
# DISABLE_ADAPTIVE_LLM_PLANNER=true       
# DISABLE_TOOL_PROVISIONER_LLM=true       
